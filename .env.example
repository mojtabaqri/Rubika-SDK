# پیکربندی Vamban Bot
# کپی کنید به .env و مقادیر خود را وارد کنید

# محیط
APP_ENV=production
APP_DEBUG=false

# پایگاه داده
DB_PATH=data/vamban.db

# توکن JWT
JWT_SECRET=your-super-secret-key-change-this-to-something-secure-at-least-32-characters

# توکن ربات روبیکا
BOT_TOKEN=your-rubika-bot-token

# شناسه چت ادمین برای اطلاعات رسانی
ADMIN_CHAT_ID=your-admin-chat-id

# اطلاعات ادمین
ADMIN_USER=admin
ADMIN_PASS=ChangeMe123!

# URL بازگشت از درگاه پرداخت
PAYMENT_RETURN_URL=https://yourdomain.com/payment/callback

# پیکربندی Zarinpal
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_API_URL=https://api.zarinpal.com/rest/v2

# CORS و امنیت
ALLOWED_ORIGIN=https://yourdomain.com

# Email اطلاع‌رسانی (اختیاری)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@yourdomain.com

# Sentry (اختیاری - برای مانیتورینگ خطاها)
SENTRY_DSN=

# تنظیمات Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
